---
import { useTranslations, getLocalizedPath } from '../i18n/utils';

interface NavItem {
  key: string;
  label: string;
  path: string;
}

interface Props {
  lang: 'en' | 'fr';
  section: string;
  activePage?: string;
}

const { lang, section, activePage = '' } = Astro.props;
const t = useTranslations(lang);

const sectionNavs: Record<string, NavItem[]> = {
  delight: [
    { key: 'labande', label: t('nav.labande'), path: '/delight/la-bande/' },
    { key: 'upcoming', label: t('nav.upcoming'), path: '/delight/upcoming-concerts/' },
    { key: 'past', label: t('nav.past'), path: '/delight/past-concerts/' },
    { key: 'schubertiades', label: t('nav.schubertiades'), path: '/delight/schubertiades/' },
    { key: 'gallery', label: t('nav.gallery'), path: '/delight/gallery/' },
  ],
  learning: [
    { key: 'academies', label: t('nav.academies'), path: '/learning/academies/' },
    { key: 'masterclasses', label: t('nav.masterclasses'), path: '/learning/masterclasses/' },
    { key: 'workshops', label: t('nav.workshops'), path: '/learning/workshops/' },
  ],
  discovery: [
    { key: 'science', label: t('nav.science'), path: '/discovery/science-culture-nature/' },
    { key: 'forum', label: t('nav.forum'), path: '/discovery/ideas-forum/' },
  ],
  sharing: [
    { key: 'books', label: t('nav.books'), path: '/sharing/books/' },
    { key: 'publishing', label: t('nav.publishing'), path: '/sharing/publishing/' },
    { key: 'library', label: t('nav.library'), path: '/sharing/virtual-library/' },
    { key: 'echoes', label: t('nav.echoes'), path: '/sharing/festival-echoes/' },
    { key: 'conferences', label: t('nav.conferences'), path: '/sharing/conferences/' },
  ],
  about: [
    { key: 'history', label: t('nav.laloingtaine'), path: '/about/history/' },
    { key: 'whynew', label: t('nav.whynew'), path: '/about/why-new-site/' },
    { key: 'whoarewe', label: t('nav.whoarewe'), path: '/about/who-are-we/' },
    { key: 'calendar', label: t('nav.calendar'), path: '/about/calendar/' },
    { key: 'howto', label: t('nav.howto'), path: '/about/how-to-get-there/' },
  ],
};

const navItems = sectionNavs[section] || [];
---

{navItems.length > 0 && (
  <nav class="sub-nav" aria-label={`${section} navigation`}>
    {navItems.map((item) => (
      <a
        href={getLocalizedPath(item.path, lang)}
        class:list={['sub-nav__link', { 'sub-nav__link--active': activePage === item.key }]}
      >
        {item.label}
      </a>
    ))}
  </nav>
)}
