---
/**
 * YearFilterBar.astro
 * Botones de filtro por año — mismo diseño que PhotoGallery.
 * Uso: <YearFilterBar years={[2024, 2023, 2022]} allLabel="All" targetId="concert-years-list" blockAttr="data-year-block" />
 */
interface Props {
  years: number[];
  allLabel?: string;
  filterId?: string;
  targetId: string;
  blockAttr?: string;
}

const {
  years,
  allLabel = "All",
  filterId = "year-filter-bar",
  targetId,
  blockAttr = "data-year-block",
} = Astro.props;
---

{
  years.length > 1 && (
    <div class="year-filter-wrapper">
      <div
        class="year-filter-bar"
        id={filterId}
        data-target={targetId}
        data-block-attr={blockAttr}
      >
        <button class="yfb-btn yfb-btn--active" data-year="all">
          {allLabel}
        </button>
        {years.map((year) => (
          <button class="yfb-btn" data-year={year.toString()}>
            {year}
          </button>
        ))}
      </div>
    </div>
  )
}

<script>
  document.querySelectorAll<HTMLElement>(".year-filter-bar").forEach((bar) => {
    const targetId = bar.dataset.target!;
    const blockAttr = bar.dataset.blockAttr || "data-year-block";
    const list = document.getElementById(targetId);
    if (!list) return;

    const blocks = list.querySelectorAll<HTMLElement>(`[${blockAttr}]`);

    function filterByYear(selected: string) {
      bar
        .querySelectorAll(".yfb-btn")
        .forEach((b) => b.classList.remove("yfb-btn--active"));
      const activeBtn = bar.querySelector(`.yfb-btn[data-year="${selected}"]`);
      if (activeBtn) activeBtn.classList.add("yfb-btn--active");

      blocks.forEach((block) => {
        const blockYear =
          block.getAttribute(blockAttr.replace(/\[|\]/g, "")) ||
          block.dataset.yearBlock;
        const show = selected === "all" || blockYear === selected;
        block.style.display = show ? "" : "none";
        if (show)
          (block as HTMLElement).style.animation = "yfbFadeIn 0.3s ease";
      });
    }

    let isDown = false;
    let startX: number;
    let scrollLeft: number;
    let dragged = false;

    bar.addEventListener("mousedown", (e) => {
      isDown = true;
      bar.classList.add("dragging");
      startX = e.pageX - bar.offsetLeft;
      scrollLeft = bar.scrollLeft;
      dragged = false;
    });

    bar.addEventListener("mouseleave", () => {
      isDown = false;
      bar.classList.remove("dragging");
    });

    bar.addEventListener("mouseup", () => {
      isDown = false;
      bar.classList.remove("dragging");
    });

    bar.addEventListener("mousemove", (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - bar.offsetLeft;
      const walk = (x - startX) * 1;
      if (Math.abs(walk) > 5) dragged = true;
      bar.scrollLeft = scrollLeft - walk;
    });

    bar.addEventListener("click", (e) => {
      if (dragged) return;

      const btn = (e.target as HTMLElement).closest<HTMLElement>(".yfb-btn");
      if (!btn) return;

      const selected = btn.dataset.year!;
      filterByYear(selected);

      if (selected === "all") {
        history.replaceState(null, "", window.location.pathname);
      } else {
        history.replaceState(null, "", `#year=${selected}`);
      }
    });

    const hash = window.location.hash;
    const match = hash.match(/year=(\d+)/);
    if (match) {
      filterByYear(match[1]);
    }
  });

  // Append current hash to language switcher links
  document
    .querySelectorAll(".lang-switcher a, .lang-switch a")
    .forEach((link) => {
      link.addEventListener("click", (e) => {
        const hash = window.location.hash;
        if (hash) {
          e.preventDefault();
          window.location.href = (link as HTMLAnchorElement).href + hash;
        }
      });
    });
</script>

<style>
  .year-filter-wrapper {
    position: relative;
    margin-bottom: var(--space-2xl);
    width: 100%;
    /* Gradient mask to indicate more content on the right */
    mask-image: linear-gradient(to right, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);
  }

  .year-filter-bar {
    display: flex;
    justify-content: flex-start;
    flex-wrap: nowrap;
    gap: var(--space-sm);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
    padding: 10px 0;
    width: 100%;
    cursor: grab;
  }

  .year-filter-bar.dragging {
    cursor: grabbing;
    user-select: none;
  }

  .year-filter-bar::-webkit-scrollbar {
    display: none; /* Chrome, Safari, etc. */
  }

  .yfb-btn {
    padding: var(--space-xs) var(--space-md);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-brown);
    font-family: var(--font-nav);
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    cursor: pointer;
    border-radius: 20px;
    transition: all var(--transition-fast);
    line-height: 1.4;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .yfb-btn:hover,
  .yfb-btn--active {
    background: var(--color-burgundy);
    color: var(--color-white);
    border-color: var(--color-burgundy);
  }

  @keyframes yfbFadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
