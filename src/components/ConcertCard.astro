---
/**
 * ConcertCard.astro
 * Displays a single concert with date badge, musicians, and program info.
 * Used in both upcoming and past concert listings.
 *
 * Modes:
 *   - default (full card with date badge)
 *   - compact={true}  → one-line grid row
 *   - archive={true}  → plain-text block: title, date, musicians, program
 */
interface Props {
  title: string;
  date: Date;
  time?: string;
  location?: string;
  musicians?: string;
  program?: string;
  description?: string;
  featured?: boolean;
  compact?: boolean;
  archive?: boolean;
  lang?: "en" | "fr";
}

const {
  title,
  date,
  time,
  location = "La Loingtaine",
  musicians = "",
  program = "",
  description,
  featured = false,
  compact = false,
  archive = false,
  lang = "en",
} = Astro.props;

const months = {
  en: [
    "Jan",
    "Feb",
    "Mar",
    "Apr",
    "May",
    "Jun",
    "Jul",
    "Aug",
    "Sep",
    "Oct",
    "Nov",
    "Dec",
  ],
  fr: [
    "Jan",
    "Fév",
    "Mar",
    "Avr",
    "Mai",
    "Juin",
    "Juil",
    "Août",
    "Sep",
    "Oct",
    "Nov",
    "Déc",
  ],
};

const monthsFull = {
  en: [
    "January",
    "February",
    "March",
    "April",
    "May",
    "June",
    "July",
    "August",
    "September",
    "October",
    "November",
    "December",
  ],
  fr: [
    "janvier",
    "février",
    "mars",
    "avril",
    "mai",
    "juin",
    "juillet",
    "août",
    "septembre",
    "octobre",
    "novembre",
    "décembre",
  ],
};

const dayNames = {
  en: [
    "Sunday",
    "Monday",
    "Tuesday",
    "Wednesday",
    "Thursday",
    "Friday",
    "Saturday",
  ],
  fr: ["dimanche", "lundi", "mardi", "mercredi", "jeudi", "vendredi", "samedi"],
};

const day = date.getDate();
const dayName = dayNames[lang][date.getDay()];
const month = months[lang][date.getMonth()];
const monthFull = monthsFull[lang][date.getMonth()];
const year = date.getFullYear();
---

{
  archive ? (
    <div class="archive-entry">
      <p class="archive-entry__date">
        {dayName}&nbsp;{day}&nbsp;{monthFull}&nbsp;{year}
      </p>
      <p class="archive-entry__title">{title}</p>
      {musicians && <p class="archive-entry__musicians">{musicians}</p>}
      {program && <p class="archive-entry__program">{program}</p>}
    </div>
  ) : compact ? (
    <div class="concert-item">
      <span class="concert-item__date">
        {month} {day}
      </span>
      <span class="concert-item__title">{title}</span>
      {musicians && <span class="concert-item__artists">{musicians}</span>}
    </div>
  ) : (
    <article
      class:list={["concert-card", { "concert-card--featured": featured }]}
    >
      <div class="concert-card__date">
        <span class="concert-card__day">{day}</span>
        <span class="concert-card__month">{month}</span>
        <span class="concert-card__year">{year}</span>
      </div>
      <div class="concert-card__details">
        <h3 class="concert-card__title">{title}</h3>
        {time && (
          <p class="concert-card__time">
            ⏰ {time} — {location}
          </p>
        )}
        {musicians && (
          <div class="concert-card__musicians">
            <span class="concert-card__musician">{musicians}</span>
          </div>
        )}
        {description && <p class="concert-card__description">{description}</p>}
        <slot />
      </div>
    </article>
  )
}

<style>
  /* --- Full Card --- */
  .concert-card {
    display: flex;
    gap: var(--space-xl);
    padding: var(--space-xl);
    background: var(--color-cream-light);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    margin-bottom: var(--space-lg);
    transition:
      transform var(--transition-normal),
      box-shadow var(--transition-normal);
  }

  .concert-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(139, 117, 101, 0.12);
  }

  .concert-card--featured {
    border-left: 4px solid var(--color-burgundy);
  }

  .concert-card__date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 80px;
    padding: var(--space-md);
    background: var(--color-burgundy);
    color: var(--color-white);
    border-radius: 6px;
    text-align: center;
    flex-shrink: 0;
  }

  .concert-card__day {
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1;
    font-family: var(--font-heading);
  }

  .concert-card__month {
    font-size: 0.9rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .concert-card__year {
    font-size: 0.75rem;
    opacity: 0.8;
  }

  .concert-card__title {
    font-size: 1.3rem;
    margin-bottom: var(--space-xs);
  }

  .concert-card__time {
    font-weight: 600;
    color: var(--color-burgundy);
    margin-bottom: var(--space-sm);
    font-size: 0.9rem;
  }

  .concert-card__musicians {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: var(--space-sm);
  }

  .concert-card__musician {
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  .concert-card__instrument {
    font-style: italic;
  }

  .concert-card__country {
    font-size: 0.8rem;
    color: var(--color-brown-light);
  }

  .concert-card__description {
    font-size: 0.95rem;
    margin-top: var(--space-sm);
  }

  /* --- Compact Item --- */
  .concert-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--space-sm) var(--space-lg);
    padding: var(--space-md);
    background: var(--color-cream-light);
    border-left: 3px solid var(--color-border);
    border-radius: 0 4px 4px 0;
    transition: border-color var(--transition-fast);
  }

  .concert-item:hover {
    border-left-color: var(--color-burgundy);
  }

  .concert-item__date {
    font-weight: 700;
    color: var(--color-burgundy);
    font-family: var(--font-nav);
    font-size: 0.85rem;
  }

  .concert-item__title {
    font-weight: 600;
    color: var(--color-text);
  }

  .concert-item__artists {
    grid-column: 2;
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  @media (max-width: 600px) {
    .concert-card {
      flex-direction: column;
      align-items: stretch;
    }

    .concert-card__date {
      flex-direction: row;
      gap: var(--space-sm);
      min-width: auto;
    }

    .concert-item {
      grid-template-columns: 1fr;
    }

    .concert-item__artists {
      grid-column: 1;
    }
  }

  /* --- Archive Entry (past-concerts plain text mode) --- */
  .archive-entry {
    padding: var(--space-sm) var(--space-md);
    border-left: 2px solid var(--color-border);
    transition: border-color var(--transition-fast);
    line-height: 1.5;
  }

  .archive-entry:hover {
    border-left-color: var(--color-burgundy);
  }

  .archive-entry__title {
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--color-text);
    margin: 0 0 2px;
  }

  .archive-entry__date {
    font-size: 1rem;
    color: var(--color-burgundy);
    font-family: var(--font-nav);
    margin: 0;
  }

  .archive-entry__musicians {
    font-size: 1rem;
    color: var(--color-text-light);
    font-style: italic;
    margin: 0;
  }

  .archive-entry__program {
    font-size: 0.9rem;
    color: var(--color-brown);
    margin: 0;
  }
</style>
