---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'fr';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="site-footer">
  <div class="container">
    <p class="footer-info">
      <span class="footer-address">{t('footer.address')}</span>
      {' '}
      <span class="footer-phone">{t('footer.reservation')}</span>
      {' '}
      <span class="footer-copyright">{t('footer.copyright')}</span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    text-align: center;
    padding: var(--space-md) var(--space-lg);
    font-size: 0.8rem;
    line-height: 1.6;
  }

  .footer-address {
    color: var(--color-burgundy);
  }

  .footer-phone {
    color: var(--color-burgundy);
  }

  .footer-copyright {
    color: var(--color-brown);
  }
</style>
