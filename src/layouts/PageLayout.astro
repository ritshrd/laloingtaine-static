---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ParchmentFrame from '../components/ParchmentFrame.astro';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  section?: 'delight' | 'learning' | 'discovery' | 'sharing' | 'about' | 'home';
}

const { title, description, section = 'home' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<BaseLayout title={title} description={description} lang={lang}>
  <ParchmentFrame>
    <!-- Header -->
    <Header lang={lang} />

    <!-- Page Content -->
    <main>
      <slot />
    </main>

    <!-- Main Navigation -->
    <Navigation lang={lang} activeSection={section} />

    <!-- Footer Row: Language Switcher + Home -->
    <div class="footer-row">
      <LanguageSwitcher lang={lang} currentPath={Astro.url.pathname} />
    </div>
  </ParchmentFrame>

  <!-- Footer -->
  <Footer lang={lang} />
</BaseLayout>

<style>
  .footer-row {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) 0 0;
    margin-top: var(--space-md);
  }
</style>
