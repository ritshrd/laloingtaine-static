---
import SectionLayout from "../../layouts/SectionLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "en/academies");
if (!entry) {
  throw new Error("Academies page content not found");
}
const { Content } = await render(entry);
---

<SectionLayout
  title={entry.data.title}
  section="learning"
  activePage="academies"
  description="String Academy at La Loingtaine — immersive summer music education near Fontainebleau."
>
  <div class="learning-page">
    <h2>{entry.data.title}</h2>

    <div class="main-text">
      <Content />
    </div>
  </div>
</SectionLayout>

<style>
  h2 {
    font-family: "Cinzel Decorative", cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .main-text {
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .learning-page {
    max-width: 800px;
    margin: 0 auto;
  }
</style>
