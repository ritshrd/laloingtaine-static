---
import SectionLayout from "../../layouts/SectionLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "en/la-bande");
if (!entry) {
  throw new Error("La Bande page content not found");
}
const { Content } = await render(entry);
---

<SectionLayout
  title={entry.data.title}
  section="delight"
  activePage="labande"
  description="Meet the core ensemble of La Loingtaine — dedicated musicians at the heart of our concerts."
  heroImage={entry.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


