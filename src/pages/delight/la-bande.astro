---
import SectionLayout from '../../layouts/SectionLayout.astro';
---

<SectionLayout title="La Bande La Loingtaine" section="delight" activePage="labande" description="Meet the core ensemble of La Loingtaine — dedicated musicians at the heart of our concerts.">
  <h2>La Bande La Loingtaine</h2>
  <p class="page-intro">
    The core ensemble of La Loingtaine, bringing together internationally renowned musicians
    who share a passion for chamber music in an intimate setting.
  </p>

  <div class="artist-grid">
    <div class="artist-card">
      <div class="artist-info">
        <h3>Aki Saulière</h3>
        <span class="artist-instrument">Violin</span>
        <p>
          Artistic director and co-founder of the concert series at La Loingtaine.
          Aki's vision guides the programming and brings together exceptional musicians
          from around the world.
        </p>
      </div>
    </div>

    <div class="artist-card">
      <div class="artist-info">
        <h3>Raphael Bell</h3>
        <span class="artist-instrument">Cello</span>
        <p>
          Co-director of the concert series. Raphael brings deep musical insight
          and a commitment to the highest artistic standards in every performance.
        </p>
      </div>
    </div>

    <div class="artist-card">
      <div class="artist-info">
        <h3>David Quiggle</h3>
        <span class="artist-instrument">Viola</span>
        <p>
          A valued member of la bande, David's rich viola sound adds depth
          and warmth to the ensemble's performances.
        </p>
      </div>
    </div>

    <div class="artist-card">
      <div class="artist-info">
        <h3>Joseph Carver</h3>
        <span class="artist-instrument">Double Bass</span>
        <p>
          Joseph brings a solid foundation to larger ensemble works,
          with a musical sensibility that perfectly complements the group.
        </p>
      </div>
    </div>

    <div class="artist-card">
      <div class="artist-info">
        <h3>Maria Bader-Kubizek</h3>
        <span class="artist-instrument">Violin</span>
        <p>
          An accomplished violinist who brings both precision and passion
          to every concert at La Loingtaine.
        </p>
      </div>
    </div>

    <div class="artist-card">
      <div class="artist-info">
        <h3>Matthew Hunt</h3>
        <span class="artist-instrument">Clarinet</span>
        <p>
          Matthew's clarinet adds a distinctive color to the ensemble,
          enabling a rich variety of chamber music repertoire.
        </p>
      </div>
    </div>
  </div>
</SectionLayout>

<style>
  .artist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  .artist-card {
    background: var(--color-cream-light);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .artist-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(139, 117, 101, 0.15);
  }

  .artist-info {
    padding: var(--space-lg);
  }

  .artist-info h3 {
    font-size: 1.3rem;
    margin-bottom: var(--space-xs);
  }

  .artist-instrument {
    display: inline-block;
    font-family: var(--font-nav);
    font-size: 0.8rem;
    color: var(--color-white);
    background: var(--color-burgundy);
    padding: 2px 10px;
    border-radius: 12px;
    margin-bottom: var(--space-md);
  }

  @media (max-width: 768px) {
    .artist-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
