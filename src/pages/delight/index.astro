---
import SectionLayout from '../../layouts/SectionLayout.astro';
---

<SectionLayout title="Delight" section="delight" description="Chamber music at La Loingtaine — concerts, galleries, and the joy of music.">
  <div class="two-col">
    <div class="section-image">
      <img
        src="/images/site/home-hero.jpg"
        alt="La Loingtaine — a charming 18th century farmhouse dedicated to music"
        width="600"
        height="450"
        loading="eager"
      />
    </div>
    <div class="section-text">
      <h2>Delight</h2>
      <blockquote class="page-quote">
        "Music is the eternal voice of the soul"
      </blockquote>
      <p>
        Chamber music concerts have been the core activity at La Loingtaine since 2005,
        directed by <strong>Aki Saulière</strong> and <strong>Raphael Bell</strong>.
        They feature high-level international musicians who often perform together
        only at La Loingtaine.
      </p>
      <p>
        After each concert, tea and treats are shared between audience and musicians,
        creating a warm and personal connection that is at the heart of our mission.
      </p>
      <p>
        Over <strong>200 concerts</strong> have been organized since 2005 by
        the Association Schubertiades, bringing exceptional chamber music to
        this intimate setting near Fontainebleau.
      </p>
    </div>
  </div>
</SectionLayout>

<style>
  .section-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(139, 117, 101, 0.2);
  }

  .section-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .page-quote {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--color-brown);
    border-left: 3px solid var(--color-burgundy);
    padding-left: var(--space-lg);
    margin-bottom: var(--space-xl);
  }
</style>
