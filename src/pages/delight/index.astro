---
import SectionLayout from '../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/delight');
if (!entry) {
  throw new Error('Delight page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="delight" 
  description="Chamber music at La Loingtaine — concerts, galleries, and the joy of music."
  heroImage={entry.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>

<style>
  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }
  .content-body {
    font-size: 1.1rem;
    line-height: 1.8;
  }
</style>
