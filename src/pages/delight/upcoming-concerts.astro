---
import SectionLayout from '../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/upcoming-concerts');
const fallbackTitle = "Upcoming Concerts";
const { Content } = entry ? await render(entry) : { Content: null };
---

<SectionLayout 
  title={entry?.data.title || fallbackTitle} 
  section="delight" 
  activePage="upcoming" 
  description="Upcoming chamber music concerts at La Loingtaine near Fontainebleau."
  heroImage={entry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry?.data.title || fallbackTitle}</h2>
    <div class="content-body">
      {Content ? <Content /> : <p>Join us for our next performances at La Loingtaine. Reservations recommended.</p>}
    </div>
  </div>
</SectionLayout>


