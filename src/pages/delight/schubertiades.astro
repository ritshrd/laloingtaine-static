---
import SectionLayout from '../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/schubertiades');
if (!entry) {
  throw new Error('Schubertiades page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="delight" 
  activePage="schubertiades" 
  description="Association Schubertiades — organizing chamber music and cultural events at La Loingtaine since 2005."
  heroImage={entry.data.image}
>
  <div class="schubertiades-content">
    <h2>{entry.data.title}</h2>
    
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>

<style>
  .schubertiades-content {
    color: var(--color-text);
    line-height: 1.6;
  }

  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    margin: var(--space-xl) 0 var(--space-md);
    color: var(--color-brown);
  }

  p {
    margin-bottom: var(--space-lg);
  }
</style>
