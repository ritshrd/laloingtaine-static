---
import SectionLayout from '../../layouts/SectionLayout.astro';
import ConcertCard from '../../components/ConcertCard.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const now = new Date();

// Get all English concerts
const allConcerts = await getCollection('concerts', (entry) => {
  return entry.id.startsWith('en/');
});

// Filter past concerts (date < today) and sort by date descending
const pastConcerts = allConcerts
  .filter((c) => new Date(c.data.date) < now)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Group by year
const concertsByYear: Record<number, typeof pastConcerts> = {};
pastConcerts.forEach((concert) => {
  const year = new Date(concert.data.date).getFullYear();
  if (!concertsByYear[year]) concertsByYear[year] = [];
  concertsByYear[year].push(concert);
});

const years = Object.keys(concertsByYear).map(Number).sort((a, b) => b - a);
---

<SectionLayout title="Past Concerts" section="delight" activePage="past" description="Archive of past chamber music concerts at La Loingtaine since 2005.">
  <h2>Past Concerts</h2>
  <p class="page-intro">
    Over 200 concerts have been organized at La Loingtaine since 2005. Here is an archive
    of our rich musical history.
  </p>

  <div class="concerts-archive">
    {years.map((year) => (
      <div class="year-section">
        <h3 class="year-heading">{year}</h3>
        <div class="concert-list-compact">
          {concertsByYear[year].map((concert) => (
            <ConcertCard
              title={concert.data.title}
              date={new Date(concert.data.date)}
              musicians={concert.data.musicians}
              compact={true}
              lang={lang}
            />
          ))}
        </div>
      </div>
    ))}

    {years.length === 0 && (
      <div class="coming-soon">
        <p>Concert archive being compiled...</p>
      </div>
    )}

    <div class="year-section">
      <h3 class="year-heading">2005–2024</h3>
      <p class="coming-soon">
        A comprehensive archive of our concert history is being prepared.
        For information about past events, please <a href="mailto:info@laloingtaine.org">contact us</a>.
      </p>
    </div>
  </div>
</SectionLayout>

<style>
  .concerts-archive {
    max-width: 800px;
    margin: 0 auto;
  }

  .year-section {
    margin-bottom: var(--space-2xl);
  }

  .year-heading {
    font-size: 1.6rem;
    padding-bottom: var(--space-sm);
    border-bottom: 2px solid var(--color-burgundy);
    margin-bottom: var(--space-lg);
  }

  .concert-list-compact {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .coming-soon {
    font-style: italic;
    color: var(--color-brown);
    padding: var(--space-lg);
    background: var(--color-cream-light);
    border-radius: 4px;
    text-align: center;
  }
</style>
