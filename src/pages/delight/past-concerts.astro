---
import SectionLayout from '../../layouts/SectionLayout.astro';
---

<SectionLayout title="Past Concerts" section="delight" activePage="past" description="Archive of past chamber music concerts at La Loingtaine since 2005.">
  <h2>Past Concerts</h2>
  <p class="page-intro">
    Over 200 concerts have been organized at La Loingtaine since 2005. Here is an archive
    of our rich musical history.
  </p>

  <div class="concerts-archive">
    <div class="year-section">
      <h3 class="year-heading">2025</h3>
      <div class="concert-list-compact">
        <div class="concert-item">
          <span class="concert-item__date">March 8</span>
          <span class="concert-item__title">International Women's Day Concert</span>
          <span class="concert-item__artists">Natsumi Dempo, Lana Herazymenko, Emily Davies, Louise de Crombrugghe, Marta Medan, Simon Adda-Reyss</span>
        </div>
      </div>
    </div>

    <div class="year-section">
      <h3 class="year-heading">2024</h3>
      <p class="coming-soon">Concert archive being compiled...</p>
    </div>

    <div class="year-section">
      <h3 class="year-heading">2005–2023</h3>
      <p class="coming-soon">
        A comprehensive archive of our concert history is being prepared.
        For information about past events, please <a href="mailto:info@laloingtaine.org">contact us</a>.
      </p>
    </div>
  </div>
</SectionLayout>

<style>
  .concerts-archive {
    max-width: 800px;
    margin: 0 auto;
  }

  .year-section {
    margin-bottom: var(--space-2xl);
  }

  .year-heading {
    font-size: 1.6rem;
    padding-bottom: var(--space-sm);
    border-bottom: 2px solid var(--color-burgundy);
    margin-bottom: var(--space-lg);
  }

  .concert-list-compact {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .concert-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--space-sm) var(--space-lg);
    padding: var(--space-md);
    background: var(--color-cream-light);
    border-left: 3px solid var(--color-border);
    border-radius: 0 4px 4px 0;
  }

  .concert-item__date {
    font-weight: 700;
    color: var(--color-burgundy);
    font-family: var(--font-nav);
    font-size: 0.85rem;
  }

  .concert-item__title {
    font-weight: 600;
    color: var(--color-text);
  }

  .concert-item__artists {
    grid-column: 2;
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .coming-soon {
    font-style: italic;
    color: var(--color-brown);
    padding: var(--space-lg);
    background: var(--color-cream-light);
    border-radius: 4px;
    text-align: center;
  }

  @media (max-width: 600px) {
    .concert-item {
      grid-template-columns: 1fr;
    }

    .concert-item__artists {
      grid-column: 1;
    }
  }
</style>
