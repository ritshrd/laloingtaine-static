---
import SectionLayout from '../../layouts/SectionLayout.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';
import { getCollection, getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/gallery');
const { Content } = entry ? await render(entry) : { Content: null };

const galleryEntries = await getCollection('gallery');

// Flatten and map gallery entries into a flat array of photos
const photos = galleryEntries.flatMap((entry) => 
  entry.data.photos.map((photo) => ({
    src: photo.image,
    alt: photo.caption || entry.data.title,
    caption: photo.caption,
    year: entry.data.year,
    category: entry.data.category
  }))
).sort((a, b) => (b.year || 0) - (a.year || 0));
---

<SectionLayout 
  title={entry?.data.title || "Photo Gallery"} 
  section="delight" 
  activePage="gallery" 
  description="Photo gallery of concerts, events, and life at La Loingtaine."
  heroImage={entry?.data.image}
>
  <div class="gallery-page-container">
    <h2>{entry?.data.title || "Photo Gallery"}</h2>
    
    <div class="content-body">
      {Content ? <Content /> : <p>Moments captured from our concerts, academies, and cultural events since 2005.</p>}
    </div>

    <div class="gallery-wrapper">
      <PhotoGallery
        photos={photos}
        showFilters={true}
        columns={3}
        id="delight-gallery"
      />
    </div>
  </div>
</SectionLayout>

<style>
  .gallery-page-container {
    color: var(--color-text);
  }

  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .intro {
    text-align: center;
    font-style: italic;
    color: var(--color-brown);
    margin-bottom: var(--space-2xl);
  }

  .gallery-wrapper {
    margin-top: 20px;
  }

  .gallery-note {
    margin-top: 40px;
    padding: 20px;
    background: #fdfaf2;
    text-align: center;
    font-size: 0.9rem;
    font-style: italic;
  }
</style>
