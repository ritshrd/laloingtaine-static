---
import HomeLayout from "../layouts/HomeLayout.astro";
import { useTranslations } from "../i18n/utils";
import { getCollection, getEntry, render } from "astro:content";

const lang = "en";
const t = useTranslations(lang);
const now = new Date();

// Get home page content
const entry = await getEntry("pages", "en/home");
if (!entry) {
  throw new Error("Home page content not found");
}
const { Content } = await render(entry);

// Get next upcoming featured concert
const allConcerts = await getCollection("concerts", (entry) => {
  return entry.id.startsWith("en/");
});

const upcomingConcerts = allConcerts
  .filter((c) => new Date(c.data.date) >= now)
  .sort(
    (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime(),
  );

const nextConcert =
  upcomingConcerts.find((c) => c.data.featured) || upcomingConcerts[0];

const months = [
  "January",
  "February",
  "March",
  "April",
  "May",
  "June",
  "July",
  "August",
  "September",
  "October",
  "November",
  "December",
];
---

<HomeLayout
  title="Home"
  heroImage={entry.data.image || "/images/site/home-hero.jpg"}
>
  <div class="home-internal-content">
    {
      nextConcert && (
        <div class="upcoming-announcement">
          <p class="announcement-date">
            {months[new Date(nextConcert.data.date).getMonth()]}{" "}
            {new Date(nextConcert.data.date).getDate()} at{" "}
            {nextConcert.data.time || "4:00 p.m."}
          </p>
          <h3 class="announcement-title">{nextConcert.data.title}</h3>
          {nextConcert.data.musicians &&
            nextConcert.data.musicians.slice(0, 2).map((m) => (
              <p class="musician-info">
                {m.name} ({m.instrument})
              </p>
            ))}
        </div>
      )
    }

    <div class="section-intro">
      <div class="content-body">
        <Content />
      </div>
    </div>

    <div class="action-buttons">
      <a href="/delight/upcoming-concerts/" class="btn-main"
        >click to get the concert schedule</a
      >
      <a href="/music-academy/" class="btn-main">discover the music academy</a>
    </div>

    <!-- About Sub-navigation -->
    <nav class="about-subnav">
      <a href="/about/history/">La Loingtaine</a>
      <a href="/about/why-new-site/">Why this new site?</a>
      <a href="/about/who-are-we/">Who are we?</a>
      <a href="/about/calendar/">Calendar</a>
      <a href="/about/how-to-get-there/">How to go there?</a>
    </nav>
  </div>
</HomeLayout>

<style>
  .home-internal-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .upcoming-announcement {
    margin-bottom: 40px;
    text-align: center;
  }

  .announcement-date {
    color: var(--color-burgundy);
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 5px;
  }

  .announcement-title {
    font-size: 1.8rem;
    margin-bottom: 10px;
  }

  .musician-info {
    font-size: 0.95rem;
    color: var(--color-text-light);
    margin-bottom: 2px;
  }

  .action-buttons {
    display: flex;
    flex-direction: column;
    gap: 15px;
    margin-bottom: 40px;
  }

  .about-subnav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 15px 25px;
    margin-top: 20px;
  }

  .about-subnav a {
    color: var(--color-burgundy);
    font-weight: 500;
  }

  .about-subnav a:hover {
    color: #4a3728;
    text-decoration: underline;
  }
</style>
