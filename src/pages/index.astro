---
import PageLayout from '../layouts/PageLayout.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import { useTranslations } from '../i18n/utils';
import { getCollection } from 'astro:content';

const lang = 'en';
const t = useTranslations(lang);
const now = new Date();

// Get next upcoming featured concert
const allConcerts = await getCollection('concerts', (entry) => {
  return entry.id.startsWith('en/');
});

const upcomingConcerts = allConcerts
  .filter((c) => new Date(c.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const nextConcert = upcomingConcerts.find(c => c.data.featured) || upcomingConcerts[0];

const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

const slides = [
  { src: '/images/site/home-hero.jpg', alt: 'La Loingtaine — 18th Century Farmhouse' },
  { src: '/images/site/home-hero.jpg', alt: 'Chamber Music Concerts' },
  { src: '/images/site/home-hero.jpg', alt: 'Music Academy for Young Professionals' },
];
---

<PageLayout title="Home" section="home">
  <!-- Hero: Carousel + Content split -->
  <div class="home-split">
    <div class="home-split__image">
      <ImageCarousel 
        slides={slides} 
        interval={5000} 
        height="500px"
        id="home-hero-carousel"
      />
    </div>
    <div class="home-split__content">
      {nextConcert ? (
        <div class="home-announcement">
          <h2 class="announcement-title">{nextConcert.data.title}</h2>
          <p class="announcement-detail">
            {months[new Date(nextConcert.data.date).getMonth()]} {new Date(nextConcert.data.date).getDate()}
            {nextConcert.data.time && ` at ${nextConcert.data.time}`}
            {` at ${nextConcert.data.location || 'La Loingtaine'}`}
          </p>
          {nextConcert.data.musicians && nextConcert.data.musicians.length > 0 && (
            <>
              <p><strong>Musicians</strong></p>
              <p>
                {nextConcert.data.musicians.map((m, i) => (
                  <>
                    {m.name}{m.country ? ` (${m.country})` : ''}{m.instrument ? `, ${m.instrument}` : ''}
                    {i < nextConcert.data.musicians!.length - 1 && <br />}
                  </>
                ))}
              </p>
            </>
          )}
        </div>
      ) : (
        <div class="home-announcement">
          <h2 class="announcement-title">Welcome to La Loingtaine</h2>
          <p>Au plus près de la culture et de la musique</p>
        </div>
      )}

      <div class="home-ctas">
        <a href="/delight/upcoming-concerts/" class="btn btn--primary">
          click to get the concert schedule
        </a>
        <a href="/learning/academies/" class="btn">
          discover the music academy
        </a>
      </div>

      <!-- About Links -->
      <nav class="about-links">
        <a href="/about/history/">La Loingtaine</a>
        <a href="/about/why-new-site/">Why this new site?</a>
        <a href="/about/who-are-we/">Who are we?</a>
        <a href="/about/calendar/">Calendar</a>
        <a href="/about/how-to-get-there/">How to go there?</a>
      </nav>
    </div>
  </div>
</PageLayout>

<style>
  .home-announcement {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .announcement-title {
    font-size: 1.3rem;
    color: var(--color-burgundy);
    margin-bottom: var(--space-sm);
    font-weight: 700;
  }

  .announcement-detail {
    font-weight: 700;
    color: var(--color-burgundy);
    margin-bottom: var(--space-md);
  }

  .home-ctas {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }
</style>
