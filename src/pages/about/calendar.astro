---
import SectionLayout from '../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/calendar');
if (!entry) {
  throw new Error('Calendar page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="about" 
  activePage="calendar" 
  description="Events calendar for La Loingtaine — concerts, masterclasses, and cultural events."
  heroImage={entry.data.image}
>
  <div class="calendar-page">
    <h2>{entry.data.title}</h2>

    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>

<style>
  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .intro {
    text-align: center;
    font-style: italic;
    color: var(--color-brown);
    margin-bottom: 40px;
  }

  .month-block {
    margin-bottom: 40px;
  }

  .month-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--color-burgundy);
    border-bottom: 2px solid #eee;
    margin-bottom: 20px;
  }

  .event-card {
    display: flex;
    gap: 20px;
    background: #fdfaf2;
    padding: 20px;
    border-radius: 4px;
    border-left: 4px solid var(--color-burgundy);
  }

  .date-badge {
    background: var(--color-burgundy);
    color: white;
    min-width: 80px;
    height: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    text-align: center;
  }

  .day {
    font-size: 1.4rem;
    font-weight: 700;
  }

  .month {
    font-size: 0.75rem;
    text-transform: uppercase;
  }

  .event-details h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    margin-bottom: 5px;
  }

  .event-details p {
    font-size: 0.95rem;
    color: #666;
  }

  .info-footer {
    margin-top: 50px;
    text-align: center;
    padding: 30px;
    border-top: 1px dashed #ccc;
    font-style: italic;
  }
</style>
