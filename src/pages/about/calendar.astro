---
import SectionLayout from '../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/calendar');
if (!entry) {
  throw new Error('Calendar page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="about" 
  activePage="calendar" 
  description="Events calendar for La Loingtaine — concerts, masterclasses, and cultural events."
  heroImage={entry.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


