---
import SectionLayout from "../../layouts/SectionLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "en/la-loingtaine");
if (!entry) {
  throw new Error("History page content not found");
}
const { Content } = await render(entry);
---

<SectionLayout
  title={entry.data.title}
  section="about"
  activePage="history"
  description="La Loingtaine — an 18th century farmhouse near Fontainebleau dedicated to music, culture, and the arts."
  heroImage={entry.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


