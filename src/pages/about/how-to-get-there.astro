---
import SectionLayout from '../../layouts/SectionLayout.astro';
import GoogleMap from '../../components/GoogleMap.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/how-to-get-there');
if (!entry) {
  throw new Error('How to get there page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="about" 
  activePage="howto" 
  description="How to get to La Loingtaine — directions by train and car to Montigny-sur-Loing."
  heroImage={entry.data.image}
>
  <div class="how-to-page">
    <h2>{entry.data.title}</h2>
    
    <div class="map-wrapper">
      <GoogleMap
        address="40 rue Grande, Sorques, 77690 Montigny sur Loing, France"
        zoom={15}
        height="350px"
      />
    </div>

    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>

<style>
  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .intro {
    text-align: center;
    font-style: italic;
    color: var(--color-brown);
    margin-bottom: 40px;
  }

  .address-box {
    text-align: center;
    background: var(--color-burgundy);
    color: white;
    padding: 30px;
    border-radius: 4px;
    margin-bottom: 30px;
  }

  .address-box h3 {
    margin-bottom: 10px;
    color: white;
  }

  .map-wrapper {
    margin-bottom: 40px;
    border: 1px solid #ddd;
    border-radius: 4px;
    overflow: hidden;
  }

  .transport-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 40px;
  }

  .transport-item {
    background: #fdfaf2;
    padding: 25px;
    border-radius: 4px;
    border: 1px solid #eee;
  }

  .transport-item h3 {
    font-family: 'Playfair Display', serif;
    margin-bottom: 15px;
    color: var(--color-burgundy);
  }

  .transport-item p {
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 10px;
  }

  .contact-footer {
    text-align: center;
    border-top: 1px dashed #ccc;
    padding-top: 30px;
  }

  @media (max-width: 600px) {
    .transport-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
