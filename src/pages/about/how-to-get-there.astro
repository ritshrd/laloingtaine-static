---
import SectionLayout from '../../layouts/SectionLayout.astro';
import GoogleMap from '../../components/GoogleMap.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/how-to-get-there');
if (!entry) {
  throw new Error('How to get there page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="about" 
  activePage="howto" 
  description="How to get to La Loingtaine — directions by train and car to Montigny-sur-Loing."
  heroImage={entry.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
    <div class="map-wrapper">
      <GoogleMap
        address="40 rue Grande, Sorques, 77690 Montigny sur Loing, France"
        zoom={15}
        height="350px"
      />
    </div>
  </div>
</SectionLayout>


