---
import SectionLayout from '../../layouts/SectionLayout.astro';
import { getCollection } from 'astro:content';

const team = await getCollection('artists', (entry) => {
  return entry.id.startsWith('en/') && (entry.data as any).order !== undefined;
});

const sortedTeam = team.sort((a, b) => ((a.data as any).order || 99) - ((b.data as any).order || 99));
---

<SectionLayout title="Who Are We?" section="about" activePage="whoarewe" description="Meet the team behind La Loingtaine — Aki Saulière, Raphael Bell, Masako Saulière, and Claude Saulière.">
  <h2>Who Are We?</h2>
  <p class="page-intro">
    The dedicated team behind La Loingtaine's cultural mission.
  </p>

  <div class="team-grid">
    {sortedTeam.map((member) => (
      <div class="team-card">
        <div class="team-info">
          <h3>{member.data.name}</h3>
          <span class="team-role">{member.data.instrument}</span>
          <p>{member.body}</p>
        </div>
      </div>
    ))}
  </div>
</SectionLayout>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  .team-card {
    background: var(--color-cream-light);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .team-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(139, 117, 101, 0.15);
  }

  .team-info {
    padding: var(--space-lg);
  }

  .team-info h3 {
    font-size: 1.3rem;
    margin-bottom: var(--space-xs);
  }

  .team-role {
    display: inline-block;
    font-family: var(--font-nav);
    font-size: 0.75rem;
    color: var(--color-white);
    background: var(--color-burgundy);
    padding: 2px 10px;
    border-radius: 12px;
    margin-bottom: var(--space-md);
  }
</style>
