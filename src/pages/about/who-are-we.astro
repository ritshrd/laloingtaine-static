---
import SectionLayout from '../../layouts/SectionLayout.astro';
---

<SectionLayout title="Who Are We?" section="about" activePage="whoarewe" description="Meet the team behind La Loingtaine — Aki Saulière, Raphael Bell, Masako Saulière, and Claude Saulière.">
  <h2>Who Are We?</h2>
  <p class="page-intro">
    The dedicated team behind La Loingtaine's cultural mission.
  </p>

  <div class="team-grid">
    <div class="team-card">
      <div class="team-info">
        <h3>Aki Saulière</h3>
        <span class="team-role">Artistic Director</span>
        <p>
          Violinist and artistic visionary, Aki directs the concert programming and
          educational activities, bringing together exceptional musicians from around the world.
        </p>
      </div>
    </div>

    <div class="team-card">
      <div class="team-info">
        <h3>Raphael Bell</h3>
        <span class="team-role">Co-Director, Music</span>
        <p>
          Cellist and co-director of the concert series, Raphael ensures the highest
          level of artistic quality and mentors young musicians through the academy.
        </p>
      </div>
    </div>

    <div class="team-card">
      <div class="team-info">
        <h3>Masako Saulière</h3>
        <span class="team-role">Research & Communications</span>
        <p>
          Masako manages research partnerships, communications, and the publishing
          activities of La Loingtaine, bridging connections between East and West.
        </p>
      </div>
    </div>

    <div class="team-card">
      <div class="team-info">
        <h3>Claude Saulière</h3>
        <span class="team-role">Accommodation & Logistics</span>
        <p>
          Claude ensures that everyone who visits La Loingtaine — musicians, students,
          and audiences alike — feels welcomed and at home.
        </p>
      </div>
    </div>
  </div>
</SectionLayout>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  .team-card {
    background: var(--color-cream-light);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .team-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(139, 117, 101, 0.15);
  }

  .team-info {
    padding: var(--space-lg);
  }

  .team-info h3 {
    font-size: 1.3rem;
    margin-bottom: var(--space-xs);
  }

  .team-role {
    display: inline-block;
    font-family: var(--font-nav);
    font-size: 0.75rem;
    color: var(--color-white);
    background: var(--color-burgundy);
    padding: 2px 10px;
    border-radius: 12px;
    margin-bottom: var(--space-md);
  }
</style>
