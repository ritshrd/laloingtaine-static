---
import SectionLayout from '../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/who-are-we');
if (!entry) {
  throw new Error('Who Are We page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="about" 
  activePage="whoarewe" 
  description="Meet the core team behind La Loingtaine — Aki Saulière, Raphael Bell, Masako Saulière, and Claude Saulière."
  heroImage={entry.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


