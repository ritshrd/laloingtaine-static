---
import SectionLayout from "../../../layouts/SectionLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "fr/test");
const enEntry = await getEntry("pages", "en/test");
if (!entry) {
  throw new Error("Test page content not found (FR)");
}
const { Content } = await render(entry);
---

<SectionLayout
  title={entry.data.title}
  section="learning"
  activePage="test"
  description="Académie de cordes à La Loingtaine — éducation musicale immersive estivale."
  heroImage={entry.data.image || enEntry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


