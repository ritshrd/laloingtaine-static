---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/academies');
if (!entry) {
  throw new Error('Academies page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="learning" 
  activePage="academies" 
  description="Académie de cordes à La Loingtaine — éducation musicale immersive estivale."
  heroImage="/images/site/home-hero.jpg"
>
  <div class="academy-info">
    <h2>{entry.data.title}</h2>
    
    <div class="main-text">
      <Content />
    </div>

    {entry.data.professors && (
      <div class="professors-section">
        <h3>Professeurs</h3>
        <ul class="professor-list">
          {entry.data.professors.map((prof) => (
            <li><strong>{prof}</strong></li>
          ))}
        </ul>
      </div>
    )}

    {entry.data.highlights && (
      <div class="highlights-grid">
        {entry.data.highlights.map((h) => (
          <div class="highlight-item">
            <span class="hl-icon">{h.icon}</span>
            <h4>{h.title}</h4>
            <p>{h.description}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</SectionLayout>

<style>
  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .main-text {
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .professors-section {
    background: #fdfaf2;
    padding: 30px;
    border-radius: 4px;
    margin-bottom: 40px;
  }

  .professors-section h3 {
    font-family: 'Playfair Display', serif;
    margin-bottom: 20px;
    color: var(--color-burgundy);
  }

  .professor-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 20px 40px;
  }

  .professor-list li::before {
    content: '●';
    color: var(--color-burgundy);
    margin-right: 10px;
    font-size: 0.7rem;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
  }

  .highlight-item {
    padding: 20px;
    background: white;
    border: 1px solid #eee;
    text-align: center;
    border-radius: 4px;
  }

  .hl-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 10px;
  }

  .highlight-item h4 {
    font-size: 1rem;
    margin-bottom: 10px;
  }

  .highlight-item p {
    font-size: 0.85rem;
    color: #666;
  }
</style>
