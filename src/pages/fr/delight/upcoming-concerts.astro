---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/upcoming-concerts');
const enEntry = await getEntry('pages', 'en/upcoming-concerts');
const fallbackTitle = "Prochains Concerts";
const { Content } = entry ? await render(entry) : { Content: null };
---

<SectionLayout 
  title={entry?.data.title || fallbackTitle} 
  section="delight" 
  activePage="upcoming" 
  description="Prochains concerts de musique de chambre à La Loingtaine."
  heroImage={entry?.data.image || enEntry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry?.data.title || fallbackTitle}</h2>
    <div class="content-body">
      {Content ? <Content /> : <p>Rejoignez-nous pour nos prochaines performances à La Loingtaine. Réservation recommandée.</p>}
    </div>
  </div>
</SectionLayout>


