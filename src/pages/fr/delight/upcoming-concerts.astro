---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import ConcertCard from '../../../components/ConcertCard.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const now = new Date();

const allConcerts = await getCollection('concerts', (entry) => {
  return entry.id.startsWith('fr/');
});

const upcomingConcerts = allConcerts
  .filter((c) => new Date(c.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());
---

<SectionLayout title="Prochains Concerts" section="delight" activePage="upcoming" description="Prochains concerts de musique de chambre à La Loingtaine.">
  <h2>Prochains Concerts</h2>
  <p class="page-intro">
    Rejoignez-nous pour nos prochaines performances à La Loingtaine.
    Réservation recommandée — contactez-nous au 01 64 45 83 14 ou 06 22 85 11 86.
  </p>

  <div class="concert-list">
    {upcomingConcerts.length > 0 ? (
      upcomingConcerts.map((concert) => (
        <ConcertCard
          title={concert.data.title}
          date={new Date(concert.data.date)}
          time={concert.data.time}
          location={concert.data.location}
          musicians={concert.data.musicians}
          featured={concert.data.featured}
          lang={lang}
        />
      ))
    ) : (
      <div class="no-concerts">
        <p>Aucun concert à venir actuellement programmé. Revenez bientôt !</p>
        <p>Pour les dernières informations, contactez-nous :</p>
        <p class="contact-info">
          <strong>Tél :</strong> 01 64 45 83 14 / 06 22 85 11 86<br />
          <strong>Email :</strong> <a href="mailto:info@laloingtaine.org">info@laloingtaine.org</a>
        </p>
      </div>
    )}
  </div>

  <div class="concert-cta">
    <p>Pour le programme complet et les réservations :</p>
    <p class="contact-info">
      <strong>Tél :</strong> 01 64 45 83 14 / 06 22 85 11 86<br />
      <strong>Email :</strong> <a href="mailto:info@laloingtaine.org">info@laloingtaine.org</a>
    </p>
  </div>
</SectionLayout>

<style>
  .concert-list { max-width: 800px; margin: 0 auto var(--space-2xl); }
  .concert-cta { text-align: center; padding: var(--space-xl); background: var(--color-cream-light); border: 1px dashed var(--color-border); border-radius: 6px; max-width: 500px; margin: 0 auto; }
  .contact-info { font-size: 0.95rem; }
  .no-concerts { text-align: center; padding: var(--space-2xl); background: var(--color-cream-light); border: 1px solid var(--color-border); border-radius: 6px; }
</style>
