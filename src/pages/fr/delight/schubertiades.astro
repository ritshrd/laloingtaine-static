import SectionLayout from '../../../layouts/SectionLayout.astro';
---

<SectionLayout title="Association Schubertiades" section="delight" activePage="schubertiades" description="Association Schubertiades — organisant musique de chambre et événements culturels à La Loingtaine depuis 2005.">
  <h2>Association Schubertiades</h2>
  <div class="two-col">
    <div>
      <p>Fondée en <strong>2005</strong>, l'Association Schubertiades a été créée pour transformer une ferme du XVIIIe siècle près de Fontainebleau en un <strong>espace culturel vivant</strong> pour la musique de chambre et les arts.</p>
      <p>Inspirée des Schubertiades du début du XIXe siècle — des réunions intimes où Franz Schubert et ses amis partageaient musique, poésie et idées — notre association perpétue cette tradition.</p>
      <p>L'association organise :</p>
      <ul>
        <li>Des concerts de musique de chambre tout au long de l'année</li>
        <li>Des académies et masterclasses pour jeunes musiciens</li>
        <li>Des événements culturels, conférences et expositions</li>
        <li>Des programmes de résidence pour artistes internationaux</li>
      </ul>
    </div>
    <div>
      <div class="info-box">
        <h3>S'impliquer</h3>
        <p>L'Association Schubertiades accueille membres, donateurs et bénévoles.</p>
        <p><strong>Contact :</strong><br />Association Schubertiades<br />40 rue Grande, Sorques<br />77690 Montigny sur Loing<br /><a href="mailto:info@laloingtaine.org">info@laloingtaine.org</a></p>
      </div>
    </div>
  </div>
</SectionLayout>
<style>
  .info-box { background: var(--color-cream-light); border: 1px solid var(--color-border); border-radius: 6px; padding: var(--space-xl); margin-top: var(--space-lg); }
  .info-box h3 { font-size: 1.2rem; margin-bottom: var(--space-md); }
</style>
