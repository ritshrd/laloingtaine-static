---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/schubertiades');
const enEntry = await getEntry('pages', 'en/schubertiades');
if (!entry) {
  throw new Error('Schubertiades page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="delight" 
  activePage="schubertiades" 
  description="Association Schubertiades — organisation de concerts de musique de chambre et d'événements culturels à La Loingtaine depuis 2005."
  heroImage={entry.data.image || enEntry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="schubertiades-content">
    <h2>{entry.data.title}</h2>
    
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>

<style>
  .schubertiades-content {
    color: var(--color-text);
  }

  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }
</style>
