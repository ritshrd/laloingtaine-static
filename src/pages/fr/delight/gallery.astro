---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import PhotoGallery from '../../../components/PhotoGallery.astro';
import { getCollection, getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/gallery');
const enEntry = await getEntry('pages', 'en/gallery');
const { Content } = entry ? await render(entry) : { Content: null };

const galleryEntries = await getCollection('gallery');

const photos = galleryEntries.flatMap((entry) => 
  entry.data.photos.map((photo) => ({
    src: photo.image,
    alt: photo.caption || entry.data.title,
    caption: photo.caption, 
    year: entry.data.year,
    category: entry.data.category
  }))
).sort((a, b) => (b.year || 0) - (a.year || 0));
---

<SectionLayout 
  title={entry?.data.title || "Galerie Photos"} 
  section="delight" 
  activePage="gallery" 
  description="Galerie photos des concerts, événements et de la vie à La Loingtaine."
  heroImage={entry?.data.image || enEntry?.data.image}
>
  <div class="gallery-page-container">
    <h2>{entry?.data.title || "Galerie Photos"}</h2>
    
    <div class="content-body">
      {Content ? <Content /> : <p>Des moments capturés de nos concerts, académies et événements culturels depuis 2005.</p>}
    </div>

    <div class="gallery-wrapper">
      <PhotoGallery
        photos={photos}
        showFilters={true}
        columns={3}
        id="delight-gallery-fr"
      />
    </div>
  </div>
</SectionLayout>

<style>
  .gallery-page-container {
    color: var(--color-text);
  }

  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }
</style>
