---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import PhotoGallery from '../../../components/PhotoGallery.astro';

const photos = [
  { src: '/images/site/home-hero.jpg', alt: 'Salle de concert à La Loingtaine', caption: 'Salle de concert', year: 2025, category: 'concerts' },
  { src: '/images/site/home-hero.jpg', alt: 'Musique de chambre à La Loingtaine', caption: 'Concert de musique de chambre', year: 2025, category: 'concerts' },
  { src: '/images/site/home-hero.jpg', alt: 'La Loingtaine extérieur', caption: 'La ferme en automne', year: 2024, category: 'general' },
  { src: '/images/site/home-hero.jpg', alt: 'Académie de musique', caption: 'Académie d\'été 2024', year: 2024, category: 'academies' },
  { src: '/images/site/home-hero.jpg', alt: 'Concert à La Loingtaine', caption: 'Rendez-vous avec Amadeus', year: 2023, category: 'concerts' },
  { src: '/images/site/home-hero.jpg', alt: 'Étudiants de l\'académie', caption: 'Performance de l\'académie 2023', year: 2023, category: 'academies' },
  { src: '/images/site/home-hero.jpg', alt: 'Festival de piano', caption: 'Festival Piano Mon Amour', year: 2022, category: 'events' },
  { src: '/images/site/home-hero.jpg', alt: 'Jardin de La Loingtaine', caption: 'Le parc le long du Loing', year: 2022, category: 'general' },
  { src: '/images/site/home-hero.jpg', alt: 'Ensemble à La Loingtaine', caption: 'Camerata La Loingtaine', year: 2021, category: 'concerts' },
];
---

<SectionLayout title="Galerie Photos" section="delight" activePage="gallery" description="Galerie photos des concerts, événements et de la vie à La Loingtaine.">
  <h2>Galerie Photos</h2>
  <p class="page-intro">
    Des moments capturés de nos concerts, académies et événements culturels depuis 2005.
  </p>

  <PhotoGallery
    photos={photos}
    showFilters={true}
    columns={3}
    id="delight-gallery-fr"
  />

  <p class="gallery-note">
    D'autres photos seront ajoutées au fur et à mesure de la migration de notre ancien site.
    Pour des photos spécifiques, <a href="mailto:info@laloingtaine.org">contactez-nous</a>.
  </p>
</SectionLayout>
