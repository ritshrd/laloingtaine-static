---
import PageLayout from '../../layouts/PageLayout.astro';
import ImageCarousel from '../../components/ImageCarousel.astro';
import { useTranslations } from '../../i18n/utils';
import { getCollection } from 'astro:content';

const lang = 'fr';
const t = useTranslations(lang);
const now = new Date();

// Get next upcoming featured concert in French
const allConcerts = await getCollection('concerts', (entry) => {
  return entry.id.startsWith('fr/');
});

const upcomingConcerts = allConcerts
  .filter((c) => new Date(c.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const nextConcert = upcomingConcerts.find(c => c.data.featured) || upcomingConcerts[0];

const months = ['janvier', 'février', 'mars', 'avril', 'mai', 'juin', 'juillet', 'août', 'septembre', 'octobre', 'novembre', 'décembre'];

const slides = [
  { src: '/images/site/home-hero.jpg', alt: 'La Loingtaine — Ferme du XVIIIe siècle' },
  { src: '/images/site/home-hero.jpg', alt: 'Concerts de musique de chambre' },
  { src: '/images/site/home-hero.jpg', alt: 'Académie de musique pour jeunes professionnels' },
];
---

<PageLayout title="Accueil" section="home">
  <!-- Hero: Carousel + Content split -->
  <div class="home-split">
    <div class="home-split__image">
      <ImageCarousel 
        slides={slides} 
        interval={5000} 
        height="500px"
        id="home-hero-carousel-fr"
      />
    </div>
    <div class="home-split__content">
      {nextConcert ? (
        <div class="home-announcement">
          <h2 class="announcement-title">{nextConcert.data.title}</h2>
          <p class="announcement-detail">
            {new Date(nextConcert.data.date).getDate()} {months[new Date(nextConcert.data.date).getMonth()]}
            {nextConcert.data.time && ` à ${nextConcert.data.time}`}
            {` à ${nextConcert.data.location || 'La Loingtaine'}`}
          </p>
          {nextConcert.data.musicians && nextConcert.data.musicians.length > 0 && (
            <>
              <p><strong>Musicians</strong></p>
              <p>
                {nextConcert.data.musicians.map((m, i) => (
                  <>
                    {m.name}{m.country ? ` (${m.country})` : ''}{m.instrument ? `, ${m.instrument}` : ''}
                    {i < nextConcert.data.musicians!.length - 1 && <br />}
                  </>
                ))}
              </p>
            </>
          )}
        </div>
      ) : (
        <div class="home-announcement">
          <h2 class="announcement-title">Bienvenue à La Loingtaine</h2>
          <p>Au plus près de la culture et de la musique</p>
        </div>
      )}

      <div class="home-ctas">
        <a href="/fr/delight/upcoming-concerts/" class="btn btn--primary">
          cliquez pour le programme des concerts
        </a>
        <a href="/fr/learning/academies/" class="btn">
          découvrir l'académie de musique
        </a>
      </div>

      <!-- About Links -->
      <nav class="about-links">
        <a href="/fr/about/history/">La Loingtaine</a>
        <a href="/fr/about/why-new-site/">Pourquoi ce nouveau site?</a>
        <a href="/fr/about/who-are-we/">Qui sommes-nous?</a>
        <a href="/fr/about/calendar/">Calendrier</a>
        <a href="/fr/about/how-to-get-there/">Comment y aller?</a>
      </nav>
    </div>
  </div>
</PageLayout>

<style>
  .home-announcement {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .announcement-title {
    font-size: 1.3rem;
    color: var(--color-burgundy);
    margin-bottom: var(--space-sm);
    font-weight: 700;
  }

  .announcement-detail {
    font-weight: 700;
    color: var(--color-burgundy);
    margin-bottom: var(--space-md);
  }

  .home-ctas {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }
</style>
