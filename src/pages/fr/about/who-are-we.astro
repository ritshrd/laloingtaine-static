---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/who-are-we');
const enEntry = await getEntry('pages', 'en/who-are-we');
if (!entry) {
  throw new Error('Who Are We page content not found (FR)');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="about" 
  activePage="whoarewe" 
  description="Rencontrez l'équipe de La Loingtaine — Aki Saulière, Raphael Bell, Masako Saulière et Claude Saulière."
  heroImage={entry.data.image || enEntry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


