---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/ideas-forum');
const enEntry = await getEntry('pages', 'en/ideas-forum');
if (!entry) {
  throw new Error('Ideas Forum page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="discovery" 
  activePage="forum" 
  description="Le Forum des Idées — un espace communautaire pour des conférences, des ateliers et des expositions à La Loingtaine."
  heroImage={entry.data.image || enEntry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="forum-container">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>

<style>
  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }
  .intro {
    text-align: center;
    font-style: italic;
    color: var(--color-brown);
    margin-bottom: 40px;
  }
  .body-text {
    font-size: 1rem;
    line-height: 1.8;
  }
  .cta-box {
    text-align: center;
    background: #fdfaf2;
    border: 1px dashed #c9b08a;
    border-radius: 4px;
    padding: 40px;
    margin-top: 50px;
  }
</style>
