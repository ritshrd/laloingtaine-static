---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/science-culture-nature');
const enEntry = await getEntry('pages', 'en/science-culture-nature');
if (!entry) {
  throw new Error('Science, Culture and Nature page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="discovery" 
  activePage="science" 
  description="Science, Culture et Nature — les Dialogues de Fontainebleau à La Loingtaine."
  heroImage={entry.data.image || enEntry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="discovery-content">
          Les sujets explorés incluent l'écologie, le développement durable, la relation entre 
          art et science, et le rôle de la culture dans la transformation sociale.
        </p>
      </div>
    </div>
  </div>
</SectionLayout>

<style>
  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .intro-text {
    font-size: 1.1rem;
    font-style: italic;
    color: var(--color-brown);
    margin-bottom: 40px;
    text-align: center;
    line-height: 1.6;
  }

  .main-body {
    font-size: 1rem;
    line-height: 1.8;
  }

  .info-card {
    background: #fdfaf2;
    border: 1px solid #ddd;
    padding: 30px;
    border-radius: 4px;
    margin-top: 40px;
  }

  .info-card h3 {
    font-family: 'Playfair Display', serif;
    margin-bottom: 15px;
    color: var(--color-burgundy);
  }
</style>
