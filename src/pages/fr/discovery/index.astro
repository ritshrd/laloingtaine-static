---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/discovery');
const enEntry = await getEntry('pages', 'en/discovery');
if (!entry) {
  throw new Error('Discovery page content not found (FR)');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="discovery" 
  description="Découverte à La Loingtaine — cultiver le savoir en science, culture et nature."
  heroImage={entry.data.image || enEntry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


