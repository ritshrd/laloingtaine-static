---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/publishing');
const enEntry = await getEntry('pages', 'en/publishing');
if (!entry) {
  throw new Error('Publishing page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="sharing" 
  activePage="publishing" 
  description="Éditions La Loingtaine — maison d'édition internationale."
  heroImage={entry.data.image || enEntry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="publishing-page">
    <h2>{entry.data.title}</h2>
    
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>

<style>
  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }
  .intro {
    text-align: center;
    font-style: italic;
    color: var(--color-brown);
    margin-bottom: 40px;
  }
  .body-text {
    font-size: 1rem;
    line-height: 1.8;
  }
  .contact-card {
    background: #fdfaf2;
    border-left: 4px solid var(--color-burgundy);
    padding: 30px;
    margin-top: 40px;
  }
</style>
