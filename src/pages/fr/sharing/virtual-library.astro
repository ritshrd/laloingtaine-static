---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/virtual-library');
const enEntry = await getEntry('pages', 'en/virtual-library');
if (!entry) {
  throw new Error('Virtual Library page content not found (FR)');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="sharing" 
  activePage="library" 
  description="Projet de Bibliothèque Virtuelle — bibliographie annotée sur l'UNESCO, la science et l'écologie."
  heroImage={entry.data.image || enEntry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


