---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/conferences');
const enEntry = await getEntry('pages', 'en/conferences');
if (!entry) {
  throw new Error('Conferences page content not found (FR)');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="sharing" 
  activePage="conferences" 
  description="Conférences à La Loingtaine — intervenants invités sur l'art, la science, la musique et le patrimoine."
  heroImage={entry.data.image || enEntry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


