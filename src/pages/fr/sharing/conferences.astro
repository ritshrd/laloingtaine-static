---
import SectionLayout from '../../../layouts/SectionLayout.astro';
---

<SectionLayout title="Conférences" section="sharing" activePage="conferences" description="Conférences à La Loingtaine — intervenants distingués.">
  <h2>Conférences</h2>
  <p class="page-intro">Des intervenants distingués partagent leurs réflexions sur l'art, la science, la musique et le patrimoine.</p>
  <div style="max-width:800px;margin:0 auto">
    <div class="speaker-list">
      <div class="speaker-card"><h3>Dr. Denis Le Bihan</h3><p class="speaker-topic">Imagerie Cérébrale et Musique</p><p>Chercheur pionnier en imagerie cérébrale, explorant les connexions fascinantes entre le cerveau et la musique.</p></div>
      <div class="speaker-card"><h3>Georges Kutukdjian</h3><p class="speaker-topic">UNESCO et Patrimoine Culturel</p><p>Figure distinguée de la politique culturelle internationale avec des décennies d'expérience à l'UNESCO.</p></div>
    </div>
    <div class="conference-cta"><p>Intéressé à assister ou proposer une conférence ?<br />Contact : <a href="mailto:info@laloingtaine.org">info@laloingtaine.org</a></p></div>
  </div>
</SectionLayout>
<style>
  .speaker-list{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-xl);margin-bottom:var(--space-2xl)}
  .speaker-card{background:var(--color-cream-light);border:1px solid var(--color-border);border-radius:6px;padding:var(--space-xl);transition:transform var(--transition-normal)}
  .speaker-card:hover{transform:translateY(-3px)}
  .speaker-card h3{font-size:1.2rem;margin-bottom:var(--space-xs)}
  .speaker-topic{font-family:var(--font-nav);font-size:.8rem;color:var(--color-white);background:var(--color-burgundy);display:inline-block;padding:2px 10px;border-radius:12px;margin-bottom:var(--space-md)}
  .conference-cta{text-align:center;padding:var(--space-xl);background:var(--color-cream-light);border:1px dashed var(--color-border);border-radius:6px}
  @media(max-width:768px){.speaker-list{grid-template-columns:1fr}}
</style>
