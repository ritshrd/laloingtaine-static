---
import SectionLayout from '../../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'fr/festival-echoes');
const enEntry = await getEntry('pages', 'en/festival-echoes');
if (!entry) {
  throw new Error('Festival Echoes page content not found (FR)');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="sharing" 
  activePage="echoes" 
  description="Échos du Festival — conférences liées au Festival international de l'histoire de l'art du Château de Fontainebleau."
  heroImage={entry.data.image || enEntry?.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


