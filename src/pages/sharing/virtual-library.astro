---
import SectionLayout from '../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/virtual-library');
if (!entry) {
  throw new Error('Virtual Library page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="sharing" 
  activePage="library" 
  description="Virtual Library Project — an annotated bibliography on UNESCO, science, and ecology."
  heroImage={entry.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


