---
import SectionLayout from '../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/virtual-library');
if (!entry) {
  throw new Error('Virtual Library page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="sharing" 
  activePage="library" 
  description="Virtual Library Project — an annotated bibliography on UNESCO, science, and ecology."
  heroImage={entry.data.image}
>
  <div class="library-page">
    <h2>{entry.data.title}</h2>
    
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>

<style>
  h2 {
    font-family: 'Cinzel Decorative', cursive;
    color: var(--color-burgundy);
    margin-bottom: var(--space-xl);
    text-align: center;
  }
  .intro {
    text-align: center;
    font-style: italic;
    color: var(--color-brown);
    margin-bottom: 40px;
  }
  .body-text {
    font-size: 1rem;
    line-height: 1.8;
  }
  .status-box {
    text-align: center;
    background: #fdfaf2;
    border: 1px dashed #c9b08a;
    padding: 30px;
    margin-top: 50px;
  }
</style>
