---
import SectionLayout from '../../layouts/SectionLayout.astro';
---

<SectionLayout title="La Loingtaine Publishing" section="sharing" activePage="publishing" description="La Loingtaine Publishing — an international publishing house for musicians, writers, and painters.">
  <h2>La Loingtaine Publishing</h2>
  <p class="page-intro">
    An international publishing house founded in 2018 in Japan, publishing musicians,
    writers, and painters.
  </p>

  <div class="publishing-content">
    <p>
      <strong>La Loingtaine Publishing</strong> extends our cultural mission to the printed page.
      Founded in 2018, the publishing house bridges the worlds of East and West, bringing
      together voices from across disciplines and cultures.
    </p>
    <p>
      Our publications include works by musicians who share their artistic insights,
      writers whose stories reflect the human experience, and painters whose visual
      narratives complement our musical mission.
    </p>

    <div class="info-box">
      <h3>Publication Inquiries</h3>
      <p>
        For information about our publications or to submit a manuscript,
        please contact: <a href="mailto:info@laloingtaine.org">info@laloingtaine.org</a>
      </p>
    </div>
  </div>
</SectionLayout>

<style>
  .publishing-content {
    max-width: 750px;
    margin: 0 auto;
  }

  .info-box {
    background: var(--color-cream-light);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-burgundy);
    border-radius: 0 6px 6px 0;
    padding: var(--space-xl);
    margin-top: var(--space-xl);
  }

  .info-box h3 {
    font-size: 1.1rem;
    margin-bottom: var(--space-md);
  }
</style>
