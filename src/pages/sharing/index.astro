---
import SectionLayout from '../../layouts/SectionLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/sharing');
if (!entry) {
  throw new Error('Sharing page content not found');
}
const { Content } = await render(entry);
---

<SectionLayout 
  title={entry.data.title} 
  section="sharing" 
  description="Sharing at La Loingtaine — lectures, books, conferences, and the joy of cultural exchange."
  heroImage={entry.data.image || "/images/site/home-hero.jpg"}
>
  <div class="section-intro">
    <h2>{entry.data.title}</h2>
    <div class="content-body">
      <Content />
    </div>
  </div>
</SectionLayout>


